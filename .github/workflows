name: Russian Media Collector

on:
  workflow_dispatch:
  schedule:
    - cron: "0 * * * *"

permissions:
  contents: write

jobs:
  run:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt

      - name: Run collector
        env:
          KEEP_HOURS: "48"
          OUT_JSON: "data/articles_latest.json"
          ARCHIVE_JSON: "data/articles_archive.json"
          TEST_MODE: "0"
        run: |
          python collector.py
          ls -la data || true

      - name: Commit updated JSON
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add data/*.json
          git commit -m "Auto-update Russian media JSON files" || echo "No changes"
          git push
